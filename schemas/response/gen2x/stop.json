{
    "title": "stop_response",
    "description": "Response for stop command",
    "type": "object",
    "required": [
        "command",
        "command_id",
        "payload",
        "response"
    ],
    "properties": {
        "command": {
            "type": "string",
            "const": "stop",
            "description": "MQTT command name that was executed"
        },
        "command_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier correlating this response to the original request"
        },
        "payload": {
            "type": "object",
            "description": "Response payload data"
        },
        "response": {
            "type": "string",
            "enum": [
                "success",
                "failure"
            ],
            "description": "Response status indicating success or failure"
        }
    },
    "examples": [
        {
            "command": "stop",
            "command_id": "c3f1a2b4-5678-4def-abcd-123456789abc",
            "payload": {},
            "response": "success"
        }
    ]
}
