{
    "title": "enable_short_range",
    "description": "Protects a tag and restricts it to respond only at close proximity (short-range mode).",
    "x-tag": "Tag Protection",
    "type": "object",
    "required": [
        "command",
        "command_id",
        "payload"
    ],
    "properties": {
        "command": {
            "type": "string",
            "const": "set_impinjGen2X",
            "description": "MQTT command name"
        },
        "command_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier to correlate request with response"
        },
        "payload": {
            "type": "object",
            "required": [
                "tagProtect"
            ],
            "properties": {
                "tagProtect": {
                    "type": "object",
                    "required": [
                        "action",
                        "password",
                        "tagID",
                        "enableShortRange"
                    ],
                    "properties": {
                        "action": {
                            "type": "string",
                            "const": "enableTagProtection",
                            "description": "Sets the tag to protected mode"
                        },
                        "password": {
                            "type": "string",
                            "minLength": 8,
                            "maxLength": 8,
                            "pattern": "^[0-9A-Fa-f]{8}$",
                            "description": "8-character hexadecimal 32-bit password"
                        },
                        "tagID": {
                            "type": "string",
                            "pattern": "^[0-9A-Fa-f]+$",
                            "description": "Hexadecimal tagID (EPC) of the target tag"
                        },
                        "enableShortRange": {
                            "type": "boolean",
                            "description": "true to enable short-range protection mode for higher security"
                        }
                    },
                    "description": "Tag protection configuration"
                }
            },
            "description": "Command payload containing the feature configuration"
        }
    },
    "examples": [
        {
            "command": "set_impinjGen2X",
            "command_id": "ea05d934-16cf-4fa4-9fa7-4c01f4bd4bea",
            "payload": {
                "tagProtect": {
                    "action": "enableTagProtection",
                    "password": "77777777",
                    "tagID": "e28011b0a5050076c4d7521a",
                    "enableShortRange": true
                }
            }
        }
    ]
}
