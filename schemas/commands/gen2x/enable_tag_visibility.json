{
    "title": "enable_tag_visibility",
    "description": "Allows the reader to see protected tags by providing the access password.",
    "x-tag": "Tag Protection",
    "type": "object",
    "required": [
        "command",
        "command_id",
        "payload"
    ],
    "properties": {
        "command": {
            "type": "string",
            "const": "set_impinjGen2X",
            "description": "MQTT command name"
        },
        "command_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier to correlate request with response"
        },
        "payload": {
            "type": "object",
            "required": [
                "tagProtect"
            ],
            "properties": {
                "tagProtect": {
                    "type": "object",
                    "required": [
                        "action",
                        "password"
                    ],
                    "properties": {
                        "action": {
                            "type": "string",
                            "const": "enableTagVisibility",
                            "description": "Enables the reader to read protected tags"
                        },
                        "password": {
                            "type": "string",
                            "minLength": 8,
                            "maxLength": 8,
                            "pattern": "^[0-9A-Fa-f]{8}$",
                            "description": "8-character hexadecimal 32-bit password"
                        }
                    },
                    "description": "Tag protection configuration"
                }
            },
            "description": "Command payload containing the feature configuration"
        }
    },
    "examples": [
        {
            "command": "set_impinjGen2X",
            "command_id": "eb8db4d8-f641-4bdb-9858-302c4dbec101",
            "payload": {
                "tagProtect": {
                    "action": "enableTagVisibility",
                    "password": "77777777"
                }
            }
        }
    ]
}
