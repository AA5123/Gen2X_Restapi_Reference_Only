            "description": "MQTT command name"
        },
        "command_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier to correlate request with response"
        },
        "payload": {
            "type": "object",
            "required": [
                "fastID"
            ],
            "properties": {
                "fastID": {
                    "type": "object",
                    "required": [
                        "enabled"
                    ],
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "const": false,
                            "description": "Disable FastID feature"
                        }
                    },
                    "description": "FastID feature configuration"
                }
            },
            "description": "Command payload containing the feature configuration"
        }
    },
    "examples": [
        {
            "command": "set_impinjGen2X",
            "command_id": "b35808c8-0e10-42a1-8f81-799e7843e5c9",
