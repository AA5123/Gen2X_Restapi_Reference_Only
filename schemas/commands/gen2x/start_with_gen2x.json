{
    "title": "start_with_gen2x",
    "description": "Starts the radio with Gen2X configuration applied. Stop the radio first before issuing this command.",
    "x-tag": "Control Commands",
    "type": "object",
    "required": [
        "command",
        "command_id",
        "payload"
    ],
    "properties": {
        "command": {
            "type": "string",
            "const": "start",
            "description": "MQTT command name"
        },
        "command_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier to correlate request with response"
        },
        "payload": {
            "type": "object",
            "required": [
                "applyImpinjGen2X"
            ],
            "properties": {
                "applyImpinjGen2X": {
                    "type": "boolean",
                    "const": true,
                    "description": "true to apply Gen2X config when starting the radio"
                }
            },
            "description": "Command payload containing the feature configuration"
        }
    },
    "examples": [
        {
            "command": "start",
            "command_id": "81dd51a2-b0d3-4099-b46a-5a3f82796ba1",
            "payload": {
                "applyImpinjGen2X": true
            }
        }
    ]
}
