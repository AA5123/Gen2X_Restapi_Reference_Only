{
    "title": "enable_tagfocus",
    "description": "Enables TagFocus so already-inventoried tags stay unresponsive, allowing the reader to focus on unread tags. Targets tags inventoried in session S1.",
    "x-tag": "TagFocus",
    "type": "object",
    "required": [
        "command",
        "command_id",
        "payload"
    ],
    "properties": {
        "command": {
            "type": "string",
            "const": "set_impinjGen2X",
            "description": "MQTT command name"
        },
        "command_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier to correlate request with response"
        },
        "payload": {
            "type": "object",
            "required": [
                "tagFocus"
            ],
            "properties": {
                "tagFocus": {
                    "type": "object",
                    "required": [
                        "enabled"
                    ],
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "const": true,
                            "description": "Enable TagFocus feature"
                        }
                    },
                    "description": "TagFocus feature configuration"
                }
            },
            "description": "Command payload containing the feature configuration"
        }
    },
    "examples": [
        {
            "command": "set_impinjGen2X",
            "command_id": "a3987547-62a8-4005-a064-485524e25bff",
            "payload": {
                "tagFocus": {
                    "enabled": true
                }
            }
        }
    ]
}
