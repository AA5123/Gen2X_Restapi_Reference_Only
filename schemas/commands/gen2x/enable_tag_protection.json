{
  "title": "enable_tag_protection",
  "description": "Locks a specific tag using Impinj TagProtect so it becomes invisible to all readers that do not have the correct password.",
  "x-tag": "Tag Protection",
  "type": "object",
  "required": ["command", "command_id", "payload"],
  "properties": {
    "command": {
      "type": "string",
      "const": "set_impinjGen2X",
      "description": "MQTT command name"
    },
    "command_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier to correlate request with response"
    },
    "payload": {
      "type": "object",
      "required": ["tagProtect"],
      "properties": {
        "tagProtect": {
          "type": "object",
          "required": ["action", "password", "tagID"],
          "properties": {
            "action": {
              "type": "string",
              "const": "enableTagProtection",
              "description": "Enables Tag Protection on the tag"
            },
            "password": {
              "type": "string",
              "minLength": 8,
              "maxLength": 8,
              "pattern": "^[0-9A-Fa-f]{8}$",
              "description": "8-character hexadecimal 32-bit password"
            },
            "tagID": {
              "type": "string",
              "description": "Tag EPC ID"
            }
          },
          "description": "Tag protection configuration"
        }
      }
    }
  },
  "examples": [
    {
      "command": "set_impinjGen2X",
      "command_id": "345d9511-40ac-4aed-894f-006df1205b99",
      "payload": {
        "tagProtect": {
          "action": "enableTagProtection",
          "password": "77777777",
          "tagID": "12348765a5050076c4d75211"
        }
      }
    }
  ]
}