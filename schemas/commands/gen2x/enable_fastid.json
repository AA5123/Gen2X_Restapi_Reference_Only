{
    "title": "enable_fastid",
    "description": "Enables FastID so tags return both EPC and TID in a single inventory response, eliminating the need for separate TID read operations.",
    "x-tag": "FastID",
    "type": "object",
    "required": [
        "command",
        "command_id",
        "payload"
    ],
    "properties": {
        "command": {
            "type": "string",
            "const": "set_impinjGen2X",
            "description": "MQTT command name"
        },
        "command_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier to correlate request with response"
        },
        "payload": {
            "type": "object",
            "required": [
                "fastID"
            ],
            "properties": {
                "fastID": {
                    "type": "object",
                    "required": [
                        "enabled"
                    ],
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "const": true,
                            "description": "Enable FastID feature"
                        }
                    },
                    "description": "FastID feature configuration"
                }
            },
            "description": "Command payload containing the feature configuration"
        }
    },
    "examples": [
        {
            "command": "set_impinjGen2X",
            "command_id": "657298d3-98de-421c-9b7c-ad3b53b7474f",
            "payload": {
                "fastID": {
                    "enabled": true
                }
            }
        }
    ]
}
