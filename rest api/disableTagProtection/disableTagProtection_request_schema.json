{
  "title": "Disable Protected Mode Request",
  "description": "Request payload for disabling TagProtect on a specific tag.",
  "type": "object",
  "required": [
    "tagProtect"
  ],
  "properties": {
    "tagProtect": {
      "type": "object",
      "description": "TagProtect configuration for disabling protection on a target tag.",
      "required": [
        "action",
        "password",
        "tagID"
      ],
      "properties": {
        "action": {
          "type": "string",
          "const": "disableTagProtection",
          "enum": ["disableTagProtection"],
          "description": "Disables Protected Mode on the specified tag."
        },
        "password": {
          "type": "string",
          "description": "8-character hexadecimal 32-bit password.",
          "minLength": 8,
          "maxLength": 8,
          "pattern": "^[0-9A-Fa-f]{8}$"
        },
        "tagID": {
          "type": "string",
          "description": "Hexadecimal tagID (EPC) of the target tag.",
          "pattern": "^[0-9A-Fa-f]+$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
