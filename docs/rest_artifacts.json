  "disableTagProtection": {
    "request_example": {
      "tagProtect": {
        "action": "disableTagProtection",
        "password": "77777777",
        "tagID": "e2801191a5030069073b426d"
      }
    },
    "request_schema": {
      "title": "Disable Impinj Protected Mode Request",
      "description": "Request payload for disabling TagProtect on a specific tag.",
      "type": "object",
      "required": [
        "tagProtect"
      ],
      "properties": {
        "tagProtect": {
          "type": "object",
          "description": "TagProtect configuration for disabling protection on a target tag.",
          "required": [
            "action",
            "password",
            "tagID"
          ],
          "properties": {
            "action": {
              "type": "string",
              "const": "disableTagProtection",
              "description": "Disables Protected Mode on the specified tag."
            },
            "password": {
              "type": "string",
              "description": "8-character hexadecimal 32-bit password.",
              "minLength": 8,
              "maxLength": 8,
              "pattern": "^[0-9A-Fa-f]{8}$"
            },
            "tagID": {
              "type": "string",
              "description": "Hexadecimal tagID (EPC) of the target tag.",
              "pattern": "^(?:[0-9A-Fa-f]{2})+$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "response_example": {
      "message": "Success: Gen2X configured. Use applyImpinjGen2X flag in start command to apply features. (Stop radio first before starting with Gen2X)"
    },
    "response_schema": {
      "title": "Disable Impinj Protected Mode Success Response",
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "examples": [
        {
          "message": "Success: Gen2X configured. Use applyImpinjGen2X flag in start command to apply features. (Stop radio first before starting with Gen2X)"
        }
      ]
    }
  },
