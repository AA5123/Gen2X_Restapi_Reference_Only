  "quietTags": {
    "request_example": {
      "tagQuieting": {
        "basic": {
          "action": "quiet",
          "tagIDs": [
            "e2801191a5030069073b426d",
            "e2801191a5030069073b426e"
          ]
        }
      }
    },
    "request_schema": {
      "title": "Quiet Tags Request",
      "description": "Request payload for quieting specific tags.",
      "type": "object",
      "required": [
        "tagQuieting"
      ],
      "properties": {
        "tagQuieting": {
          "type": "object",
          "description": "Tag quieting configuration.",
          "required": [
            "basic"
          ],
          "properties": {
            "basic": {
              "type": "object",
              "description": "Basic tag quieting settings.",
              "required": [
                "action",
                "tagIDs"
              ],
              "properties": {
                "action": {
                  "type": "string",
                  "const": "quiet",
                  "description": "Silence the specified tags."
                },
                "tagIDs": {
                  "type": "array",
                  "description": "List of hexadecimal EPC strings of tags to quiet.",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "pattern": "^(?:[0-9A-Fa-f]{2})+$"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "response_example": {
      "message": "Success: Gen2X configured. Use applyImpinjGen2X flag in start command to apply features. (Stop radio first before starting with Gen2X)"
    },
    "response_schema": {
      "title": "Quiet Tags Success Response",
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "examples": [
        {
          "message": "Success: Gen2X configured. Use applyImpinjGen2X flag in start command to apply features. (Stop radio first before starting with Gen2X)"
        }
      ]
    }
  },
